    },
    {
      "id": "dare-118",
      "text": "做一个“听到音乐想摇摆但很克制”的动作。"
    },
    {
      "id": "dare-119",
      "text": "给今天的聚会编一个副标题。"
    },
    {
      "id": "dare-120",
      "text": "用温柔客服语气处理“快乐不足”的问题。"
    },
    {
      "id": "dare-121",
      "text": "和任意一位玩家轮流说出三种颜色，不能重复。"
    },
    {
      "id": "dare-122",
      "text": "假装自己是博物馆讲解员，介绍一件普通物品。"
    },
    {
      "id": "dare-123",
      "text": "用三个词概括你现在的状态。"
    },
    {
      "id": "dare-124",
      "text": "给大家说一句适合写在明信片上的话。"
    },
    {
      "id": "dare-125",
      "text": "模仿一只熊慢慢醒来的表情。"
    },
    {
      "id": "dare-126",
      "text": "用电影导演语气指导大家摆一个轻松表情。"
    },
    {
      "id": "dare-127",
      "text": "在十秒内说出五个适合周末做的事情。"
    },
    {
      "id": "dare-128",
      "text": "为今晚创造一个虚构节日名称。"
    },
    {
      "id": "dare-129",
      "text": "用播客开场语气介绍你自己。"
    },
    {
      "id": "dare-130",
      "text": "做一个“发现菜单上有喜欢的菜”的反应。"
    },
    {
      "id": "dare-131",
      "text": "给任意一个普通物品安排一句内心独白。"
    },
    {
      "id": "dare-132",
      "text": "用手势表演一种运动，让大家猜。"
    },
    {
      "id": "dare-133",
      "text": "把“我来了”说成主持人登场的感觉。"
    },
    {
      "id": "dare-134",
      "text": "给大家推荐一个保持好心情的小习惯。"
    },
    {
      "id": "dare-135",
      "text": "假装自己是星球居民，介绍地球人的聚会方式。"
    },
    {
      "id": "dare-136",
      "text": "在十五秒内说出四种让房间更舒服的元素。"
    },
    {
      "id": "dare-137",
      "text": "用一句话给今晚做一句宣传语。"
    },
    {
      "id": "dare-138",
      "text": "摆一个“正在接受采访”的姿势三秒。"
    },
    {
      "id": "dare-139",
      "text": "用旁白语气描述某位玩家的一个积极特点。"
    },
    {
      "id": "dare-140",
      "text": "和任意一位玩家进行一轮同字开头词语挑战。"
    },
    {
      "id": "dare-141",
      "text": "给自己设计一个适合今晚的头像描述。"
    },
    {
      "id": "dare-142",
      "text": "用温暖的语气对大家说一句收尾祝福。"
    },
    {
      "id": "dare-143",
      "text": "模仿一只兔子听到声音后的表情，动作保持小幅度。"
    },
    {
      "id": "dare-144",
      "text": "用一本正经的语气介绍“如何正确坐着玩游戏”。"
    },
    {
      "id": "dare-145",
      "text": "在十秒内说出三种你喜欢的香味。"
    },
    {
      "id": "dare-146",
      "text": "给今晚设计一个虚构奖杯名字。"
    },
    {
      "id": "dare-147",
      "text": "用剧场报幕员语气宣布一位玩家登场。"
    },
    {
      "id": "dare-148",
      "text": "做一个“刚完成任务”的轻松庆祝动作。"
    },
    {
      "id": "dare-149",
      "text": "给大家编一句不超过十个字的队训。"
    },
    {
      "id": "dare-150",
      "text": "用咖啡店店员语气推荐一种心情饮品。"
    },
    {
      "id": "dare-151",
      "text": "任选一个玩家，请对方给你一个轻松关键词并即兴回应。"
    },
    {
      "id": "dare-152",
      "text": "用手势表达一种食物，让大家猜。"
    },
    {
      "id": "dare-153",
      "text": "假装自己是城市宣传片旁白，介绍今晚的现场。"
    },
    {
      "id": "dare-154",
      "text": "把“谢谢大家”说出三种不同风格。"
    },
    {
      "id": "dare-155",
      "text": "给一个不存在的乐队起名，并说明风格。"
    },
    {
      "id": "dare-156",
      "text": "用三秒钟摆出“非常可靠”的姿势。"
    },
    {
      "id": "dare-157",
      "text": "在十五秒内说出五种适合拍成电影的日常场景。"
    },
    {
      "id": "dare-158",
      "text": "用童话旁白语气描述一个普通杯子或碗。"
    },
    {
      "id": "dare-159",
      "text": "给今晚的聊天选一个主题曲风格。"
    },
    {
      "id": "dare-160",
      "text": "用主持人语气邀请下一位玩家继续游戏。"
    },
    {
      "id": "dare-161",
      "text": "做一个“想装酷但失败了”的表情。"
    },
    {
      "id": "dare-162",
      "text": "给大家提出一个下一轮的轻松玩法建议。"
    },
    {
      "id": "dare-163",
      "text": "用一句话夸今天的座位安排。"
    },
    {
      "id": "dare-164",
      "text": "和任意一位玩家轮流说出三种动物，不能重复。"
    },
    {
      "id": "dare-165",
      "text": "假装自己是时间管理员，宣布快乐时间延长。"
    },
    {
      "id": "dare-166",
      "text": "用手势做出一个虚构按钮，并说明按下后会发生什么。"
    },
    {
      "id": "dare-167",
      "text": "给自己安排一个适合今晚的角色身份。"
    },
    {
      "id": "dare-168",
      "text": "用新闻连线语气采访空气中的“快乐现场”。"
    },
    {
      "id": "dare-169",
      "text": "在十秒内说出四个你喜欢的城市元素。"
    },
    {
      "id": "dare-170",
      "text": "摆一个“被好运砸中”的定格姿势三秒。"
    },
    {
      "id": "dare-171",
      "text": "用轻松的语气向大家推荐一种休息方式。"
    },
    {
      "id": "dare-172",
      "text": "给任意一位玩家送一个不夸张的赞美称号。"
    },
    {
      "id": "dare-173",
      "text": "用动画反派但不吓人的语气说一句欢迎词。"
    },
    {
      "id": "dare-174",
      "text": "模仿一只海豹鼓掌的感觉，可以只用表情和小动作。"
    },
    {
      "id": "dare-175",
      "text": "给今晚编一个像章节标题的名字。"
    },
    {
      "id": "dare-176",
      "text": "用生活博主口吻分享一个整理桌面的小妙招。"
    },
    {
      "id": "dare-177",
      "text": "把“轮到你了”说得像电影经典台词。"
    },
    {
      "id": "dare-178",
      "text": "在十五秒内说出五个能代表快乐的小物件。"
    },
    {
      "id": "dare-179",
      "text": "用侦探语气指出现场最有故事感的物品。"
    },
    {
      "id": "dare-180",
      "text": "做一个“突然听懂了”的表情。"
    },
    {
      "id": "dare-181",
      "text": "给大家设计一句合照时可以喊的口号，但不要求真的拍照。"
    },
    {
      "id": "dare-182",
      "text": "用电台点歌语气把一首不存在的歌送给大家。"
    },
    {
      "id": "dare-183",
      "text": "和任意一位玩家进行一轮快速二选一问答，各说三个选择。"
    },
    {
      "id": "dare-184",
      "text": "假装自己是餐厅菜单设计师，给今晚设计一道菜名。"
    },
    {
      "id": "dare-185",
      "text": "用手势表达“安静的快乐”。"
    },
    {
      "id": "dare-186",
      "text": "给一位玩家的今日状态送一个积极形容词。"
    },
    {
      "id": "dare-187",
      "text": "用旁白语气描述自己接下来三秒的动作。"
    },
    {
      "id": "dare-188",
      "text": "在十秒内说出三种适合聚会的灯光氛围。"
    },
    {
      "id": "dare-189",
      "text": "摆一个“主角终于出场”的姿势三秒。"
    },
    {
      "id": "dare-190",
      "text": "用一句话把今晚说成一次小冒险。"
    },
    {
      "id": "dare-191",
      "text": "给大家发明一个只属于今晚的问候语。"
    },
    {
      "id": "dare-192",
      "text": "模仿一只鸟看到好天气的反应，动作保持在座位附近。"
    },
    {
      "id": "dare-193",
      "text": "用严谨学术语气解释“为什么聊天会让人开心”。"
    },
    {
      "id": "dare-194",
      "text": "任选一个物品，给它起一个像人名的名字。"
    },
    {
      "id": "dare-195",
      "text": "把“我同意”说成三种不同角色的感觉。"
    },
    {
      "id": "dare-196",
      "text": "给今晚的大家送一句不超过十五个字的祝福。"
    },
    {
      "id": "dare-197",
      "text": "用主持人口吻总结你刚才的表现。"
    },
    {
      "id": "dare-198",
      "text": "在十五秒内说出五种让人有安全感的日常物品。"
    },
    {
      "id": "dare-199",
      "text": "做一个“正在努力忍住笑”的表情。"
    },
    {
      "id": "dare-200",
      "text": "给下一位玩家安排一个温和的出场介绍。"
    }
  ]
}
